<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="30.0"
      style="-fx-background-color: #f5f5dc;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.SubscriberController">
      
          <!-- Logo -->
    <ImageView fx:id="logoImageView" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
        <image>
            <Image url="@/images/BistroLogo.png" />
        </image>
    </ImageView>

    <padding>
        <Insets bottom="20" left="40" right="40" top="40" />
    </padding>

    <!-- Header -->
<!-- Header -->
<VBox alignment="CENTER" spacing="5">
    <Label style="-fx-text-fill: #5d4037; -fx-font-weight: bold;" text=" Welcome, Subscriber! 👋">
        <font>
            <Font name="System Bold" size="32.0" />
        </font>
    </Label>
</VBox>


    <!-- Buttons Grid -->
    <GridPane alignment="CENTER" hgap="25.0" vgap="20.0">
        <columnConstraints>
            <ColumnConstraints halignment="CENTER" percentWidth="50" />
            <ColumnConstraints halignment="CENTER" percentWidth="50" />
        </columnConstraints>

        <!-- Column 1 -->
        <Button onAction="#onDisplayOrders" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="🛒 My Orders" GridPane.columnIndex="0" GridPane.rowIndex="0" />

        <Button onAction="#onNewReservation" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="📝 New Reservation" GridPane.columnIndex="0" GridPane.rowIndex="1" />

        <Button onAction="#onwaitinglist" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="⏳ Waiting List" GridPane.columnIndex="0" GridPane.rowIndex="2" />

        <Button onAction="#onEditPersonalInfo" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="✏ Edit Personal Info" GridPane.columnIndex="0" GridPane.rowIndex="3" />

        <!-- Column 2 -->
        <Button onAction="#onReceiveTable" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="🍽 Receive Table" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Button onAction="#onCancelOrder" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="❌ Cancel Order" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Button onAction="#onDisplayOrdersHistory" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;"
                text="📜 My Order History" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Button onAction="#onLogOut" prefHeight="70.0" prefWidth="300.0"
                style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-text-fill: #e40909; -fx-cursor: hand;"
                text="❌ Log Out" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <!-- Bottom buttons -->
    <HBox alignment="CENTER" spacing="25">
        <Button fx:id="prevButton" managed="false" onAction="#onPrevious" prefWidth="150.0"
                style="-fx-background-radius: 20; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-text-fill: #5d4037; -fx-font-weight: bold;"
                text="⬅ Previous Page" visible="false" />
    </HBox>

</VBox>
