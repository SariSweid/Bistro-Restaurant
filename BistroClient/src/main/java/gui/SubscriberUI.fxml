<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="BOTTOM_LEFT" prefHeight="300.0" prefWidth="400.0" spacing="14.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.SubscriberController">

    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <Label text=" Welcome !">
        <font>
            <Font size="26.0" />
        </font>
    </Label>

    <Button onAction="#onDisplayOrders" prefWidth="260" style="-fx-background-radius: 15;" text="My Orders" />
    <Button onAction="#onNewReservation" prefWidth="260" style="-fx-background-radius: 15;" text="New Reservation" />
   <Button onAction="#onwaitinglist" prefWidth="260" style="-fx-background-radius: 15;" text="Waiting List" />
    
    <Button onAction="#onEditPersonalInfo" prefWidth="260" style="-fx-background-radius: 15;" text="Edit Personal info" />
   <Button onAction="#onReceiveTable" prefWidth="260" style="-fx-background-radius: 15;" text="Recive Table" />
    <Button onAction="#onCancelOrder" prefWidth="260" style="-fx-background-radius: 15;" text="Cancel Order" />
   <Button onAction="#onDisplayOrdersHistory" prefWidth="260" style="-fx-background-radius: 15;" text="My Order History" />
    <Button onAction="#onLogOut" prefWidth="100" text="Log Out" />
    <Button fx:id="prevButton" managed="false" onAction="#onPrevious" prefWidth="100" text="Previous Page" visible="false" />
    

</VBox>
