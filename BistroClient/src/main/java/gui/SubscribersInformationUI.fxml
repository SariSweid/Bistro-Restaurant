<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="500" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.SubscriberInformationController">

	<children>
		<VBox spacing="10" style="-fx-background-color: #f5f5dc;" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">

			
			<Label style="-fx-font-size: 18px; -fx-font-weight:bold;" text="Subscribers" />	
			
            <TableView fx:id="SubscribersTable" prefHeight="250">
                <columns>
                    <TableColumn fx:id="IdColumn" prefWidth="45.60003316402435" text="User ID" />
                    <TableColumn fx:id="NameColumn" prefWidth="73.59998321533203" text="Name" />
                    <TableColumn fx:id="PhoneColumn" prefWidth="92.80005645751953" text="Phone" />
                    <TableColumn fx:id="EmailColumn" prefWidth="70" text="Email" />
                    <TableColumn fx:id="UserNameColumn" prefWidth="80.79998779296875" text="UserName" />
					<TableColumn fx:id="CodeColumn" prefWidth="129.60003662109375" text="MemberShipCode" /> 
                                
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button onAction="#onPreviousPage" prefWidth="100" style="-fx-background-radius: 15;" text="Previous page" />
                       
            </HBox>

		</VBox>
	</children>

</AnchorPane>
