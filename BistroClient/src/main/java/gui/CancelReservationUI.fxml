<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="600.0" spacing="14.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.CancelReservationController">
    
    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <TableView fx:id="reservationsTable" prefHeight="300" prefWidth="600">
        <columns>
            <TableColumn fx:id="idCol" text="Reservation ID" prefWidth="100"/>
            <TableColumn fx:id="dateCol" text="Date" prefWidth="150"/>
            <TableColumn fx:id="timeCol" text="Time" prefWidth="150"/>
            <TableColumn fx:id="guestsCol" text="Guests" prefWidth="100"/>
        </columns>
    </TableView>

    <Button fx:id="cancelButton" text="Cancel Selected Reservation" prefWidth="250" onAction="#onCancelSelected"/>
    <Button text="Previous Page" prefWidth="150" onAction="#onPreviousPage"/>
</VBox>
