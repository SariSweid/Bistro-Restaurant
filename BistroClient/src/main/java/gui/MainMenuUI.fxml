<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="14.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.MainMenuController">

    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>
   <ImageView fx:id="logoImageView" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
      <image>
         <Image url="@../../../../../../../../../BistroLogo.png" />
      </image>
   </ImageView>

    <Label text="Bistro - Main Menu">
        <font>
            <Font size="26.0" />
        </font>
    </Label>

    <Button onAction="#onLogin" prefWidth="260" style="-fx-background-radius: 12;" text="Login" />
    <Button onAction="#onRegister" prefWidth="260" style="-fx-background-radius: 15;" text="Register" />
    <Button onAction="#onGuestReservation" prefWidth="260" style="-fx-background-radius: 15;" text="Guest Reservation" />
    <Button onAction="#onPayment" prefWidth="260" style="-fx-background-radius: 15;" text="Payment" />
    <Button onAction="#onExit" prefWidth="260" text="Exit" />

</VBox>
