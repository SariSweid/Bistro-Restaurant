<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.MainMenuController">

    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <!-- Logo -->
    <ImageView fx:id="logoImageView" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
        <image>
            <Image url="@/images/BistroLogo.png" />
        </image>
    </ImageView>

    <!-- Title -->
    <Label style="-fx-text-fill: #5d4037; -fx-font-weight: bold;" text="Bistro - Main Menu">
        <font>
            <Font size="26.0" />
        </font>
    </Label>

    <!-- Buttons -->
    <VBox alignment="CENTER" spacing="15">

        <Button onAction="#onLogin" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;" text="🔑 Login" />

		<Button onAction="#onGuestReservation" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;" text="📝 Guest Reservation" />


        <Button onAction="#onwaitinglist" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;" text="⏳ Waiting List" />

        <Button onAction="#onReceiveTable" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;" text="🍽 Receive Table" />

        <Button onAction="#onPayment" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-cursor: hand;" text="💳 Payment" />

        <Button onAction="#onExit" prefHeight="60" prefWidth="280" style="-fx-background-radius: 25; -fx-background-color: #ffffff; -fx-border-color: #d7ccc8; -fx-font-weight: bold; -fx-text-fill: #e40909; -fx-cursor: hand;" text="❌ Exit" />
    </VBox>

</VBox>
