<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="354.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.TableRecivingController">
    
    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>


    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Enter Your Confirmation Code In order To Receive A Table" textAlignment="CENTER" wrapText="true" />
   <TextField maxWidth="-Infinity" prefHeight="26.0" prefWidth="100.0" />

   
    <Button onAction="#onEnter" prefWidth="250" style="-fx-font-weight: bold;" text="Enter" textFill="#0e9104" />

  
    <Button onAction="#onForgot" prefWidth="250" style="-fx-font-weight: bold; -fx-background-radius: 15;" text="Forgot My Confirmation Code" textFill="#e10505" />

    
    <Button onAction="#onPreviousPage" prefWidth="250" style="-fx-background-radius: 15;" text="Previous Page" />
    
</VBox>
