<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="14.0" style="-fx-background-color: #f5f5dc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ManagerController">

    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <Label text=" Welcome ! ">
        <font>
            <Font size="26.0" />
        </font>
    </Label>
    
    <Button onAction="#onShowSubscribersReport" prefWidth="260" style="-fx-background-radius: 15;" text="Show Suscribers Report" />
    <Button onAction="#onShowTimesReport" prefWidth="260" style="-fx-background-radius: 15;" text="Show Times Report" />
   <Button onAction="#onsupervisorscreen" prefWidth="260" style="-fx-background-radius: 15;" text="Supervisor Screen" />
   <Button onAction="#onsubscriberscreen" prefWidth="260" style="-fx-background-radius: 15;" text="Subscriber Screen" />
    <Button onAction="#onLogOut" prefWidth="100" text="Log Out" />

</VBox>
