<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450" prefWidth="430" style="-fx-background-color: #f5f5dc;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.CurrentDinersController">

    <children>
        <VBox spacing="15" style="-fx-background-color: #f5f5dc;"
              AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
              AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

            <!-- Title -->
            <Label text="Current Diners"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;" />

            <!-- Table -->
            <TableView fx:id="CurrentDinersTable" prefHeight="330">
                <columns>
                    <TableColumn fx:id="IdColumn" text="Customer ID" prefWidth="80" />
                    <TableColumn fx:id="TableIdColumn" text="Table ID" prefWidth="80" />
                    <TableColumn fx:id="GuestsColumn" text="Number of Diners" prefWidth="120" />
                    <TableColumn fx:id="TimeColumn" text="Seated Time" prefWidth="120" />
                </columns>
            </TableView>

            <!-- Buttons -->
            <HBox spacing="10">
                <Button text="Previous Page"
                        onAction="#onPreviousPage"
                        prefWidth="140"
                        style="-fx-background-radius: 15; -fx-font-size: 14px;" />
            </HBox>

        </VBox>
    </children>

</AnchorPane>
