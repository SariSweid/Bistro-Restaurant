<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" prefHeight="450" prefWidth="600" spacing="14"
      style="-fx-background-color: #f5f5dc;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.SubscriberWaitingListController">

    <Label text="Waiting List" style="-fx-font-size: 26; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="300"/>
        </columnConstraints>

        <children>
            <Label text="Number of Diners:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="numberOfDiners" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Time:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="timeComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Confirmation Code:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="confirmationCodeField" promptText="Enter code" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        </children>
    </GridPane>

    <HBox spacing="15">
        <Button fx:id="takePlaceButton" onAction="#ontakeplace" text="Take a Place!" style="-fx-background-radius: 15; -fx-background-color: #deb887; -fx-text-fill: white;"/>
        <Button fx:id="removeButton" onAction="#onRemoveFromWaitingList" text="Remove from Waiting List" style="-fx-background-radius: 15; -fx-background-color: #ff6b6b; -fx-text-fill: white;"/>
        <Button fx:id="previousPageButton" onAction="#onPreviousPage" text="Previous Page" style="-fx-background-radius: 15; -fx-background-color: #deb887; -fx-text-fill: white;"/>
    </HBox>

</VBox>
