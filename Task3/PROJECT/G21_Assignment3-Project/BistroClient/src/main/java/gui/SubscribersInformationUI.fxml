<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600" prefWidth="900" style="-fx-background-color: #f5f5dc;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.SubscriberInformationController">

    <children>
        <VBox spacing="20" style="-fx-background-color: #f5f5dc;"
              AnchorPane.topAnchor="15" AnchorPane.leftAnchor="15"
              AnchorPane.rightAnchor="15" AnchorPane.bottomAnchor="15">

          
            <Label text="Subscribers"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;" />

           
            <TableView fx:id="SubscribersTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="IdColumn" text="ID" prefWidth="60" />
                    <TableColumn fx:id="NameColumn" text="Name" prefWidth="120" />
                    <TableColumn fx:id="PhoneColumn" text="Phone" prefWidth="120" />
                    <TableColumn fx:id="EmailColumn" text="Email" prefWidth="160" />
                    <TableColumn fx:id="UserNameColumn" text="Username" prefWidth="110" />
                    <TableColumn fx:id="CodeColumn" text="Membership Code" prefWidth="140" />
                </columns>
            </TableView>

          
            <HBox spacing="15">
                <Button text="Previous Page"
                        onAction="#onPreviousPage"
                        prefWidth="140"
                        style="-fx-background-radius: 15; -fx-font-size: 14px;" />

                <Button fx:id="showHistoryButton"
                        text="Show Booking and Visit History for Subscriber"
                        onAction="#onShowHistory"
                        prefWidth="300"
                        style="-fx-background-radius: 15; -fx-font-size: 14px;"
                        disable="true" />
            </HBox>

        </VBox>
    </children>

</AnchorPane>
