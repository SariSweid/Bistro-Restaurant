<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="server.ServerUIController"
            prefWidth="400" prefHeight="300">

    <!-- Title Label -->
    <Label text="Connected Clients" layoutX="20" layoutY="20"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <!-- ListView for client info -->
    <ListView fx:id="clientsListView" layoutX="20" layoutY="60"
              prefWidth="360" prefHeight="180" />

    <!-- Status Label -->
    <Label fx:id="statusLabel" text="Status: Waiting for clients..."
           layoutX="20" layoutY="260" />

</AnchorPane>

