<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="client.GuestReservationUI"
            prefWidth="400" prefHeight="300">


	<children>
		<VBox spacing="10">
			<!-- Title -->
			<Label text="Guest Reservations" style="-fx-font-size: 18px; -fx-font-weight:bold;"/>	
			
			            <!-- Table of reservations -->
            <TableView fx:id="reservationsTable" prefHeight="250">
                <columns>
                    <TableColumn fx:id="idColumn"     text="ID"     prefWidth="80" />
                    <TableColumn fx:id="dateColumn"   text="Date"   prefWidth="150" />
                    <TableColumn fx:id="guestsColumn" text="Guests" prefWidth="80" />
                    <!-- you can add more columns later (name, phone, etc.) -->
                </columns>
            </TableView>

            <!-- Edit fields -->
            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120" />
                    <ColumnConstraints prefWidth="200" />
                </columnConstraints>

                <children>
                    <Label text="Reservation ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="reservationIdField"
                               GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Date:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="dateField"
                               promptText="yyyy-mm-dd"
                               GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="Guests:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <TextField fx:id="guestsField"
                               GridPane.rowIndex="2" GridPane.columnIndex="1" />
                </children>
            </GridPane>

            <!-- Buttons -->
            <HBox spacing="10">
                <Button text="Load Reservations"
                        onAction="#onLoadReservations" />
                <Button text="Update Reservation"
                        onAction="#onUpdateReservation" />
            </HBox>

            <!-- Status message -->
            <Label fx:id="statusLabel" text="Status: Ready" />	
		</VBox>
	</children>

</AnchorPane>

